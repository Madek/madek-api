#!/usr/bin/env bash
set -euo pipefail

# Checks all project dependencies (direct + transitive) against the OSV
# vulnerability database.
#
# Uses `clojure -X:deps list` to get the fully resolved dep graph (including
# Clojars-hosted packages), converts it to osv-scanner's JSON lockfile format,
# and feeds it directly to osv-scanner — no pom.xml or Maven Central resolution
# involved.
#
# Prerequisite: osv-scanner must be installed.
#   macOS:  brew install osv-scanner
#   other:  https://google.github.io/osv-scanner/installation/

PROJECT_DIR="$(cd -- "$(dirname "${BASH_SOURCE}")" ; cd .. > /dev/null 2>&1 && pwd -P)"

${PROJECT_DIR}/bin/env/java-setup
${PROJECT_DIR}/bin/env/clojure-setup

DEPS_JSON=$(mktemp /tmp/clj-osv-scan-temp.json)

cleanup() {
  rm -f "${DEPS_JSON}"
}
trap cleanup EXIT

cd "${PROJECT_DIR}"

# Resolve all deps (direct + transitive) including the :cljs alias, then
# convert `group/artifact version` lines to osv-scanner's JSON lockfile format.
# Git-sha based deps are skipped (not in the Maven ecosystem).
clojure -X:deps list :aliases '[:cljs]' 2>/dev/null | \
  awk '
    BEGIN { printf "{\"results\":[{\"packages\":["; first=1 }
    NF < 2 { next }
    length($2) == 40 && $2 ~ /^[0-9a-fA-F]+$/ { next }
    {
      gsub("/", ":", $1)
      if (!first) printf ","
      printf "{\"package\":{\"name\":\"%s\",\"version\":\"%s\",\"ecosystem\":\"Maven\"}}", $1, $2
      first = 0
    }
    END { printf "]}]}\n" }
  ' > "${DEPS_JSON}"

# Scan against the OSV database.
# Exits non-zero when vulnerabilities are found.
# Pass extra flags to override defaults, e.g.: bin/osv-check --format vertical
osv-scanner scan source \
  --format markdown \
  --config "${PROJECT_DIR}/osv-scanner/osv-scanner.toml" \
  --lockfile "osv-scanner:${DEPS_JSON}" \
  "$@"

# vi: ft=sh
